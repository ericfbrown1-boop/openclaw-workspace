flowchart TD
    Eric["👤 Eric<br/>(Telegram / Web)"]

    subgraph Orchestrator["🤖 Jarvis — Orchestrator (Opus 4.6)"]
        J_route{{"Classify & Route"}}
        J_merge["Merge Reviews<br/>Final PLAN.md"]
        J_relay["Relay Audit Prompt"]
        J_done["✅ Ship It"]
    end

    subgraph Planning["Phase 1: Architecture"]
        P["📐 Architect — Planner<br/>(Opus 4.6)<br/>System design, PLAN.md"]
        GPT["🧠 Grok 4.20 Beta Adversarial Review<br/>Fresh perspective + production stress-test"]
        COND_PRE["🚂 Conductor Preflight<br/>(Sonnet 4.6)<br/>Docker, Railway, env vars"]
    end

    subgraph Implementation["Phase 2: Build"]
        C["⚙️ Scotty — Coder<br/>(Sonnet 4.6)<br/>Code + CHECKPOINT.md"]
    end

    subgraph Testing["Phase 3: Test"]
        T["🧪 Tester<br/>Import verify + test suite"]
    end

    subgraph QualityGate["Phase 4: Quality Gate"]
        Q_SEC["🔍 Inspector — Security<br/>(Sonnet 4.6)<br/>Secrets, deps, Tailscale"]
        Q_CODE["🔍 Inspector — Quality<br/>(Sonnet 4.6)<br/>Best practices, patterns"]
    end

    subgraph Audit["Phase 5: External Review"]
        A["🛡️ External Auditor<br/>(Sonnet 4.6)<br/>repomix + Grok option"]
    end

    subgraph Deploy["Phase 6: Deploy"]
        COND["🚂 Conductor<br/>(Sonnet 4.6)<br/>Docker → Railway → Smoke"]
    end

    subgraph Research["Research Path"]
        R["🔬 Oracle — Researcher<br/>(Sonnet 4.6)<br/>Web, financial, competitive"]
    end

    subgraph Background["Always Running"]
        M["📡 Sentinel — Monitor<br/>(Sonnet 4.6)<br/>Stocks, prices, health"]
    end

    %% Main code flow
    Eric -->|"New project"| J_route
    J_route -->|"Plan it"| P
    P -->|"Draft"| GPT
    P -->|"Check infra"| COND_PRE
    GPT -->|"Review notes"| J_merge
    COND_PRE -->|"Env ready ✅"| J_merge
    J_merge -->|"Final PLAN.md"| C
    C -->|"HANDOFF.md"| T
    T -->|"❌ FAIL"| C
    T -->|"✅ PASS"| Q_SEC
    T -->|"✅ PASS"| Q_CODE
    Q_SEC -->|"🔴 CRITICAL"| C
    Q_SEC -->|"✅ CLEAN"| A
    Q_CODE -->|"✅ CLEAN"| A
    A -->|"Grok review?"| J_relay
    J_relay -->|"Ask Eric"| Eric
    A -->|"Done"| COND
    COND -->|"Deployed ✅"| J_done
    J_done -->|"Report"| Eric

    %% Research flow
    Eric -->|"Research request"| J_route
    J_route -->|"Research"| R
    R -->|"Findings"| Eric

    %% Error flow
    Eric -->|"Bug / error"| J_route
    J_route -->|"Diagnose"| Q_SEC

    %% Monitor
    Eric -.->|"Alerts"| M
    M -.->|"Notifications"| Eric

